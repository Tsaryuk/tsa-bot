# Telegram Bot Token (required)
# Get it from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (optional)
# If set, uses OpenAI Whisper API for transcription
# If not set, falls back to local faster-whisper
OPENAI_API_KEY=

# Local Whisper model settings (used when OPENAI_API_KEY is not set)
# Available models: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=base
# Device: cpu or cuda
WHISPER_DEVICE=cpu
# Compute type: int8, float16, float32
WHISPER_COMPUTE_TYPE=int8

# Download directory for temporary audio files
DOWNLOADS_DIR=/tmp/tsa-bot-downloads

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
